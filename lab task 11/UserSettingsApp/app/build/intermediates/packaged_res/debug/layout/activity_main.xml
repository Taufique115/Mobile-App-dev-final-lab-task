<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_compass"
            android:contentDescription="University Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Student Portal Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvNameLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etStudentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Enter your name"
            android:inputType="textPersonName"
            android:textColor="#212121"
            android:textColorHint="#999999"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvThemeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Theme"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etStudentName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/rgTheme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvThemeLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:textColor="#212121"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rbDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="#212121"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rbSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Default"
                android:textColor="#212121"
                android:layout_weight="1" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvNotifLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Notifications"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/rgTheme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable Push Notifications"
            android:textColor="#212121"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvNotifLabel"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvLangLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/switchNotif"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Spinner
            android:id="@+id/spinnerLang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:entries="@array/languages"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvLangLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFontLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Font Size"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerLang"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFontValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Font Size: 16sp"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerLang"
            app:layout_constraintEnd_toEndOf="parent" />

        <SeekBar
            android:id="@+id/seekBarFont"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="12"
            android:progress="4"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvFontLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/seekBarFont"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Reset to Default"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/btnSave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnViewSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="View Saved Settings"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:layout_constraintTop_toBottomOf="@id/btnReset"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
